{
  "models": [
    {
      "unique_name": "tpcds",
      "name": "TPC-DS",
      "measures": [
        {
          "unique_name": "Total Store Sales",
          "name": "Total Store Sales",
          "expression": "[ss_sales_price]",
          "aggregation_type": "SUM",
          "folder": "Sales",
          "format_string": "#,##0.00"
        },
        {
          "unique_name": "Store Returns",
          "name": "Store Returns",
          "expression": "[sr_return_amt]",
          "aggregation_type": "SUM",
          "folder": "Returns",
          "format_string": "#,##0.00"
        }
      ],
      "dimensions": [
        {
          "unique_name": "Store Region",
          "name": "Store Region",
          "folder": "Geography"
        },
        {
          "unique_name": "Customer Segment",
          "name": "Customer Segment",
          "folder": "Customer"
        }
      ]
    }
  ]
}
